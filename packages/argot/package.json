{
  "type": "module",
  "name": "argot",
  "version": "1.0.26",
  "description": "Per-project shorthand vocabularies for coding agents: a lossless substitution codec over an AGENTS.dict file.",
  "homepage": "https://veyyon.dev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/santhreal/veyyon.git",
    "directory": "packages/argot"
  },
  "bugs": {
    "url": "https://github.com/santhreal/veyyon/issues"
  },
  "keywords": [
    "agents",
    "codec",
    "context",
    "vocabulary"
  ],
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "check": "biome check . && bun run check:types",
    "check:types": "tsgo -p tsconfig.json --noEmit",
    "lint": "biome lint .",
    "test": "bun test --parallel",
    "bench": "bun bench/argot-bench.ts",
    "fix": "biome check --write --unsafe .",
    "fmt": "biome format --write ."
  },
  "dependencies": {
    "smol-toml": "catalog:"
  },
  "devDependencies": {
    "@types/bun": "catalog:"
  },
  "engines": {
    "bun": ">=1.3.14"
  },
  "files": [
    "src",
    "SPEC.md",
    "README.md",
    "INTEGRATING.md"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./*": {
      "types": "./src/*.ts",
      "import": "./src/*.ts"
    },
    "./*.js": "./src/*.ts"
  }
}

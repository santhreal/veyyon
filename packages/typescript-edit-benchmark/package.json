{
  "type": "module",
  "private": true,
  "name": "@veyyon/typescript-edit-benchmark",
  "version": "0.0.1",
  "description": "Edit benchmark suite using TypeScript source code mutations",
  "homepage": "https://veyyon.dev",
  "author": "santhreal",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/santhreal/veyyon.git",
    "directory": "packages/typescript-edit-benchmark"
  },
  "exports": {
    "./*": {
      "types": "./src/*.ts",
      "import": "./src/*.ts"
    },
    "./*.js": "./src/*.ts"
  },
  "scripts": {
    "check": "biome check . && bun run check:types",
    "check:types": "tsgo -p tsconfig.json --noEmit",
    "lint": "biome lint .",
    "test": "bun test --parallel",
    "fix": "biome check --write --unsafe .",
    "fmt": "biome format --write .",
    "generate": "bun run src/generate.ts --typescript-dir /tmp/pi-mono-source --count-per-type 4"
  },
  "dependencies": {
    "@babel/generator": "catalog:",
    "@babel/parser": "catalog:",
    "@babel/traverse": "catalog:",
    "@babel/types": "catalog:",
    "@veyyon/hashline": "catalog:",
    "@veyyon/agent-core": "catalog:",
    "@veyyon/coding-agent": "catalog:",
    "@veyyon/utils": "catalog:",
    "argot": "workspace:*",
    "diff": "catalog:",
    "prettier": "catalog:",
    "regexp-tree": "catalog:",
    "@veyyon/ai": "catalog:",
    "@veyyon/tui": "catalog:"
  },
  "devDependencies": {
    "@types/babel__generator": "catalog:",
    "@types/babel__traverse": "catalog:",
    "@types/bun": "catalog:"
  },
  "engines": {
    "bun": ">=1.3.14"
  }
}

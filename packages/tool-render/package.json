{
	"type": "module",
	"name": "@veyyon/tool-render",
	"version": "1.0.21",
	"description": "Shared React tool-call renderers for Veyyon HTML export and collab-web",
	"homepage": "https://veyyon.dev",
	"author": "Can Boluk",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/santhreal/veyyon.git",
		"directory": "packages/tool-render"
	},
	"bugs": {
		"url": "https://github.com/santhreal/veyyon/issues"
	},
	"keywords": ["tool-render", "react", "veyyon", "agent"],
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"scripts": {
		"check": "biome check . && bun run check:types",
		"check:types": "tsgo -p tsconfig.json --noEmit",
		"lint": "biome lint .",
		"test": "bun test --parallel",
		"fix": "biome check --write --unsafe .",
		"fmt": "biome format --write ."
	},
	"dependencies": {
		"@veyyon/utils": "catalog:",
		"@veyyon/wire": "catalog:",
		"react": "catalog:"
	},
	"devDependencies": {
		"@types/bun": "catalog:",
		"@types/react": "catalog:"
	},
	"peerDependencies": {
		"react": "catalog:",
		"react-dom": "catalog:"
	},
	"engines": {
		"bun": ">=1.3.14"
	},
	"files": ["src", "README.md"],
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts"
		},
		"./tool-render.css": "./src/tool-render.css",
		"./*": {
			"types": "./src/*.ts",
			"import": "./src/*.ts"
		},
		"./*.js": "./src/*.ts"
	}
}

{
  "type": "module",
  "name": "@veyyon/utils",
  "version": "1.0.7",
  "description": "Shared utilities for pi packages",
  "homepage": "https://veyyon.dev",
  "author": "Can Boluk",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/santhreal/veyyon.git",
    "directory": "packages/utils"
  },
  "bugs": {
    "url": "https://github.com/santhreal/veyyon/issues"
  },
  "keywords": [
    "utilities",
    "cli",
    "logging",
    "streams"
  ],
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "check": "biome check . && bun run check:types",
    "check:types": "tsgo -p tsconfig.json --noEmit",
    "lint": "biome lint .",
    "test": "bun test --parallel",
    "fix": "biome check --write --unsafe .",
    "fmt": "biome format --write ."
  },
  "dependencies": {
    "@veyyon/natives": "catalog:",
    "handlebars": "catalog:",
    "winston": "catalog:",
    "winston-daily-rotate-file": "catalog:"
  },
  "devDependencies": {
    "@types/bun": "catalog:"
  },
  "engines": {
    "bun": ">=1.3.14"
  },
  "files": [
    "src",
    "README.md",
    "CHANGELOG.md"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./*": {
      "types": "./src/*.ts",
      "import": "./src/*.ts"
    },
    "./*.js": "./src/*.ts"
  }
}

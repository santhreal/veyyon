{
  "type": "module",
  "name": "@veyyon/swarm-extension",
  "version": "1.0.2",
  "description": "Swarm orchestration extension for veyyon",
  "homepage": "https://veyyon.dev",
  "author": "Derek Rynd",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/santhreal/veyyon.git",
    "directory": "packages/swarm-extension"
  },
  "bugs": {
    "url": "https://github.com/santhreal/veyyon/issues"
  },
  "keywords": [
    "swarm",
    "orchestration",
    "agent",
    "extension"
  ],
  "bin": {
    "veyyon-swarm": "src/cli.ts"
  },
  "scripts": {
    "check": "biome check . && bun run check:types",
    "check:types": "tsgo -p tsconfig.json --noEmit",
    "lint": "biome lint .",
    "fix": "biome check --write --unsafe .",
    "fmt": "biome format --write ."
  },
  "dependencies": {
    "@veyyon/utils": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14"
  },
  "peerDependencies": {
    "@veyyon/coding-agent": "catalog:"
  },
  "engines": {
    "bun": ">=1.3.14"
  },
  "veyyon": {
    "extensions": [
      "./src/extension.ts"
    ]
  },
  "files": [
    "src",
    "README.md",
    "CHANGELOG.md"
  ]
}
